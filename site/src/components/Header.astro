---
import { withBase } from "../lib/site";

interface Props {
  active?: string;
  repoUrl: string;
}
const { active, repoUrl } = Astro.props;

const nav = [
  { key: "components", label: "Components", href: withBase("/components") },
  { key: "groups", label: "Groups", href: withBase("/#groups") },
  { key: "about", label: "About", href: withBase("/#about") },
];
---

<header class="site-header">
  <div class="container bar">
    <a class="brand" href={withBase("/")} aria-label="Compose Playground home">
      <span class="logo" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="currentColor" aria-hidden="true">
          <circle cx="24" cy="32" r="18" />
          <path d="M33 21.5 L58.5 29.5 L33 39.5 Z" />
          <circle cx="27.5" cy="26" r="3" fill="var(--paper)" />
        </svg>
      </span>
      <span class="brand-text">Compose<span class="muted">Playground</span></span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((n) => (
        <a href={n.href} class:list={["nav-link", { active: active === n.key }]}>{n.label}</a>
      ))}
    </nav>

    <div class="actions">
      <button class="icon-btn" data-search-open aria-label="Search components" title="Search (press /)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      <button type="button" class="corvid-theme-toggle" data-corvid-theme-toggle aria-pressed="false" aria-label="Switch to dark theme" title="Switch theme">
        <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2" />
          <path d="M12 2.6v2.4M12 19v2.4M4.2 4.2l1.7 1.7M18.1 18.1l1.7 1.7M2.6 12h2.4M19 12h2.4M4.2 19.8l1.7-1.7M18.1 5.9l1.7-1.7" />
        </svg>
        <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A8.6 8.6 0 1 1 11.2 3a6.7 6.7 0 0 0 9.8 9.8z" />
        </svg>
      </button>
      <a class="btn btn-ghost gh" href={repoUrl} target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5A11.5 11.5 0 0 0 .5 12 11.5 11.5 0 0 0 8 22.9c.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/></svg>
        <span class="gh-text">GitHub</span>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    height: var(--header-h);
    backdrop-filter: blur(14px) saturate(140%);
    background: var(--header-bg);
    border-bottom: 1px solid var(--hairline);
  }
  .bar { height: var(--header-h); display: flex; align-items: center; gap: 18px; }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 900; letter-spacing: -0.02em; color: var(--ink); }
  .brand:hover { text-decoration: none; }
  .brand-text .muted { margin-left: 4px; font-weight: 500; color: var(--ink-70); }
  .logo { display: inline-flex; width: 26px; height: 26px; color: var(--ink); }
  .logo svg { width: 100%; height: 100%; }

  .nav { display: flex; gap: 4px; margin-left: 12px; }
  .nav-link { color: var(--ink-70); padding: 8px 12px; border-radius: 0; font-weight: 600; font-size: 0.92rem; }
  .nav-link:hover { color: var(--ink); background: var(--ink-06); text-decoration: none; }
  .nav-link.active { color: var(--sheen-strong); background: var(--ink-06); box-shadow: inset 0 -2px 0 var(--sheen); }

  .actions { margin-left: auto; display: flex; align-items: center; gap: 8px; }
  .icon-btn {
    display: inline-grid; place-items: center; width: 34px; height: 34px;
    border-radius: 0; border: 1px solid var(--ink-12); background: none;
    color: var(--ink-70); cursor: pointer; transition: border-color .2s, color .2s;
  }
  .icon-btn:hover { border-color: var(--sheen); color: var(--sheen); }
  .gh { padding: 0.5em 0.9em; }
  /* sun/moon toggle styles live in global.css (they key off <html data-theme>) */

  @media (max-width: 760px) {
    .nav { display: none; }
    .gh-text { display: none; }
  }
</style>
