---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Search from "../components/Search.astro";
import { meta, withBase } from "../lib/site";

interface Props {
  title: string;
  description?: string;
  /** active top-nav key */
  active?: string;
}

const {
  title,
  description = "A Jetpack Compose + Material 3 component gallery — 52 components with pixel-accurate previews and copy-paste Kotlin.",
  active,
} = Astro.props;

const ogImage = withBase("/screenshots/home-light.png");
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={withBase("/brand/favicon.svg")} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@400;500;700;900&family=Spline+Sans+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {/* CorvidLabs pre-paint: ?theme= or stored choice before first paint, no flash */}
    <script is:inline>
      (() => {
        try {
          const q = new URLSearchParams(location.search).get("theme");
          const t = q || localStorage.getItem("corvid-theme");
          if (t === "light" || t === "dark") document.documentElement.dataset.theme = t;
        } catch (_) {}
      })();
    </script>
    <script is:inline src={withBase("/brand/theme.js")} defer></script>
  </head>
  <body>
    <a href="#main" class="sr-only">Skip to content</a>
    <Header active={active} repoUrl={meta.repoUrl} />
    <main id="main">
      <slot />
    </main>
    <Footer repoUrl={meta.repoUrl} />
    <Search />
  </body>
</html>
